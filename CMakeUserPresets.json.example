{
  "version": 6,
  "configurePresets": [
    {
      "name": "native-local",
      "displayName": "ArtCade native runtime (local)",
      "inherits": "native-runtime",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "native-local-release",
      "configurePreset": "native-local",
      "targets": ["artcade_editor_core_roundtrip_test"]
    }
  ]
}
