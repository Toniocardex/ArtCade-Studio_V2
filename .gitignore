# Local toolchain installers (not part of the project)
.installers/

# Asset-encryption secret (never commit; back up out-of-band)
runtime-cpp/secrets/

# Build artifacts
build/
build-*/
runtime-cpp/build/
runtime-cpp/build-*/
dist/

# Third-party libraries (large binaries, fetched at configure time)
runtime-cpp/libs/
tools/
!runtime-cpp/tools/
!runtime-cpp/tools/**
*.exe
*.dll
*.so
*.dylib
*.o
*.obj
*.a
*.lib
*.zip

# CMake
CMakeUserPresets.json
.qt-prefix.path
cmake-build-debug/
cmake-build-release/
CMakeCache.txt
CMakeFiles/
Makefile

# Emscripten
*.wasm
*.wasm.map
*.js.map
*.js~

# Python
__pycache__/
*.pyc
*.pyo

# Node/npm (optional root helpers only)
node_modules/
yarn.lock
package-lock.json
*.log
artcade-vite*.log
runtime-cpp/build-wasm*.log
runtime-cpp/test-project/logs/*.txt
!runtime-cpp/test-project/logs/.gitkeep

# Claude / Cursor (machine-local except shared agent rules)
.claude/settings.local.json
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/c_cpp_properties.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store

# Temp/Dev
.env
.env.local
temp/
tmp/
*.tmp

# Asset development
assets/dev/
*.psd
*.aseprite
*.ase

# Runtime outputs
*.artcade.debug
profile-*.json

# Large optional assets
ico_1920x1504.png
ArtCade_ICO.png
ArtCade_ico.svg
ArtCade_logo_noName.svg
docs/*.pdf

