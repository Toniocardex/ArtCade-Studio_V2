{
  "configurations": [
    {
      "name": "WASM-Emscripten",
      "compilerPath": "${env:USERPROFILE}/emsdk/upstream/emscripten/em++.exe",
      "compileCommands": "${workspaceFolder}/runtime-cpp/build-wasm/compile_commands.json",
      "intelliSenseMode": "linux-clang-x64",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "defines": [],
      "includePath": [
        "${workspaceFolder}/runtime-cpp/src/**",
        "${env:USERPROFILE}/emsdk/upstream/emscripten/cache/sysroot/include",
        "${env:USERPROFILE}/emsdk/upstream/emscripten/system/include"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/runtime-cpp/src",
          "${env:USERPROFILE}/emsdk/upstream/emscripten/system/include"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    },
    {
      "name": "Win32-Native",
      "compilerPath": "cl.exe",
      "compileCommands": "${workspaceFolder}/runtime-cpp/build-native/compile_commands.json",
      "intelliSenseMode": "windows-msvc-x64",
      "cStandard": "c17",
      "cppStandard": "c++17"
    }
  ],
  "version": 4
}
