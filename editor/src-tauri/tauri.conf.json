{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArtCade Editor",
  "version": "2.0.0",
  "identifier": "it.artcade.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:release"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ArtCade Editor",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "maximized": true,
        "decorations": true,
        "resizable": true,
        "visible": false,
        "backgroundColor": "#1A1A1A"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset: https://asset.localhost http://asset.localhost https://tauri.localhost http://tauri.localhost tauri: customprotocol:",
        "connect-src": "ipc: http://ipc.localhost 'self' http://localhost:* https://asset.localhost http://asset.localhost https://tauri.localhost http://tauri.localhost",
        "script-src": "'self' 'unsafe-inline' 'wasm-unsafe-eval' asset: https://asset.localhost http://asset.localhost https://tauri.localhost http://tauri.localhost blob:",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: asset: https://asset.localhost http://asset.localhost blob:",
        "worker-src": "'self' blob: data: asset: https://asset.localhost http://asset.localhost https://tauri.localhost http://tauri.localhost",
        "font-src": "'self' asset: https://asset.localhost http://asset.localhost"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/runtime-cpp-sdk.zip",
      "resources/tools/pack-artcade.py",
      "resources/scripts/bootstrap-artcade-sdk.ps1",
      "resources/scripts/bootstrap-runtime-libs.ps1"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
