{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LogicBoard",
  "type": "object",
  "required": ["boardId", "target", "events"],
  "properties": {
    "boardId": { "type": "string", "minLength": 1 },
    "name": { "type": "string" },
    "target": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["object_type", "global", "scene"] },
        "objectTypeId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false,
      "if": { "properties": { "type": { "const": "object_type" } } },
      "then": { "required": ["type", "objectTypeId"] }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "enabled", "trigger", "actions"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" },
          "onlyIfEnabled": { "type": "boolean" },
          "conditionsOperator": { "enum": ["AND", "OR", "NOT"] },
          "trigger": {
            "description": "Discriminated trigger union — expanded at compile time from triggers.json"
          },
          "conditions": {
            "type": "array",
            "description": "Condition union items — expanded at compile time from conditions.json"
          },
          "conditionRoot": {
            "description": "Condition union — expanded at compile time from conditions.json"
          },
          "actions": {
            "type": "array",
            "description": "Action union items — expanded at compile time from actions.json"
          },
          "elseEnabled": { "type": "boolean" },
          "elseActions": {
            "type": "array",
            "description": "Action union items — expanded at compile time from actions.json"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
