{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "native-runtime",
      "displayName": "ArtCade native runtime",
      "description": "Runtime-cpp + headless editor_core.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "native-release",
      "configurePreset": "native-runtime",
      "targets": ["artcade_editor_core_roundtrip_test"]
    }
  ]
}
